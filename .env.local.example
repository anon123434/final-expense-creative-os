# Copy this file to .env.local and fill in your values.

# ── Supabase ──────────────────────────────────────────────────────────────
# Find these in your Supabase dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── LLM Providers ────────────────────────────────────────────────────────
# Both keys are optional. When missing, generators fall back to built-in mocks.
#
# Claude API (generateConcepts, generateScript, variations, transforms)
ANTHROPIC_API_KEY=sk-ant-...
#
# OpenAI API (generateVOScript, generateVisualPlan, generateScenePromptPack)
OPENAI_API_KEY=sk-...
